# Local credentials for CDT download scripts.
# Keep the real .env only on your machine. Commit this example file, not the real one.

# NASA Earthdata / GPM IMERG
# Used by: scripts_descarga/gpm_imerg_v07_to_cdt.py
EARTHDATA_USERNAME=your_earthdata_user
EARTHDATA_PASSWORD=your_earthdata_password

# JAXA GSMaP FTP
# Used by: scripts_descarga/gsmap_clm_to_cdt.py
GSMAP_FTP_USER=your_gsmap_ftp_user
GSMAP_FTP_PASSWORD=your_gsmap_ftp_password

# Copernicus Climate Data Store / ERA5-Land
# Used by: scripts_descarga/era5_land_1hr_to_cdt.py
CDS_TOKEN=your_cds_api_token